# Local development (docker-compose db). Copy to .env and adjust.
DATABASE_URL=postgresql+psycopg://pm:pm@localhost:5433/portfolio

# Production: the Supabase POOLER URI (Settings -> Database -> Connection pooling),
# with the scheme changed to postgresql+psycopg://.
# Use the pooler host, never db.<ref>.supabase.co -- that one is IPv6-only and Render
# cannot reach it. Percent-encode any @ # ? in the password.
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase Auth. AUTH_ENABLED=false leaves the app open (local dev only).
AUTH_ENABLED=false

# Settings -> API. The "Project URL".
SUPABASE_URL=

# The PUBLISHABLE key (sb_publishable_...), formerly called "anon". Public by design --
# it ships to the browser so Supabase Auth can sign you in.
# NEVER put the SECRET key (sb_secret_..., formerly "service_role") anywhere in this app:
# it bypasses row-level security and would undo the PostgREST lockdown migration.
SUPABASE_ANON_KEY=

# LEAVE THIS EMPTY on a modern project.
# Supabase now signs user tokens with asymmetric keys (ECC/RSA) and publishes the public
# half at a JWKS endpoint, which the app fetches automatically -- no secret needed.
# Only set this if your project still uses the legacy shared "JWT Secret" (HS256).
# Setting it tells the app to expect HS256 and nothing else.
SUPABASE_JWT_SECRET=

# Bearer token the GitHub Actions cron presents to POST /api/refresh.
REFRESH_TOKEN=dev-refresh-token

# Minutes a cached price stays fresh before we re-fetch.
PRICE_CACHE_TTL_MINUTES=15
